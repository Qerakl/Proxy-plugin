{
  "manifest_version": 3,
  "name": "G - Proxy",
  "version": "1.9.0",
  "description": "Быстрое подключение HTTP, HTTPS и SOCKS5 прокси с гео и проверкой (Firefox)",
  "permissions": [
    "proxy",
    "storage",
    "webRequest",
    "webRequestBlocking",
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "G - Proxy"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "g-proxy@qerakl.github",
      "strict_min_version": "125.0"
    }
  }
}
